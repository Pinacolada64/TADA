# ignore Python bytecode caches
__pycache__/

# ignore .prg binaries
*.prg

# ignore .d64/d81 disk images
*.[dD]64
*.[dD]81

# ignore EditPad (Pro) __history backup folders (no * wildcard needed)
__history/**

# ignore virtual environment .venv directory
server/.venv/**

# ignore JetBrains IDE stuff
/.idea/**

# ignore tada-client build artifacts (regenerated by `make build`/`make vice`)
assembly-language/client/*_pp.asm
assembly-language/client/*.sym
assembly-language/client/*-vice-labels
assembly-language/client/monitor-commands
